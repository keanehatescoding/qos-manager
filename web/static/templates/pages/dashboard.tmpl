{{ define "content" }}
<main class="flex-1 p-8 space-y-8 overflow-y-auto">
	<!-- Stats Cards -->
	<section class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">
				Active Rules
			</p>

			<h3 class="mt-2 text-3xl font-bold">
				{{ .Stats.TotalTargets }}
			</h3>
		</div>

		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">
				Managed Domains
			</p>

			<h3 class="mt-2 text-3xl font-bold">
				{{ .Stats.TotalDomains }}
			</h3>
		</div>

		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">
				Managed IPs
			</p>

			<h3 class="mt-2 text-3xl font-bold">
				{{ .Stats.TotalIPs }}
			</h3>
		</div>
	</section>

	<section class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">
				High Priority Targets
			</p>

			<h3 class="mt-2 text-3xl font-bold">
				{{ .Stats.HighPrioTargets }}
			</h3>
		</div>

		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">
				Low Priority Rules
			</p>

			<h3 class="mt-2 text-3xl font-bold">
				{{ .Stats.LowPrioTargets }}
			</h3>
		</div>

		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">
				QoS Engine
			</p>

			<div class="mt-3 flex items-center gap-2">
				{{ if .Enabled }}
				<div class="h-3 w-3 rounded-full bg-green-500"></div>

				<span class="font-medium text-green-400">
					Active
				</span>
				{{ else }}
				<div class="h-3 w-3 rounded-full bg-red-500"></div>

				<span class="font-medium text-red-400">
					Inactive
				</span>
				{{ end }}
			</div>
		</div>

	</section>

	<!-- Traffic Rules Table -->
	<section class="rounded-2xl border border-zinc-800 bg-zinc-900">

		<div class="flex items-center justify-between border-b border-zinc-800 px-6 py-4">

			<div>
				<h3 class="text-lg font-semibold">
					Recent Traffic Rules
				</h3>

				<p class="text-sm text-zinc-400">
					Currently active QoS policies
				</p>
			</div>

			<button class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium transition hover:bg-blue-500">
				<a href="/rules">Add Rule</a>
			</button>

		</div>

		<div class="overflow-x-auto">

			<table class="w-full text-left">

				<thead class="border-b border-zinc-800 bg-zinc-950/50">
					<tr>
						<th class="px-6 py-4 text-sm font-medium text-zinc-400">
							Type
						</th>

						<th class="px-6 py-4 text-sm font-medium text-zinc-400">
							Target
						</th>

						<th class="px-6 py-4 text-sm font-medium text-zinc-400">
							Priority
						</th>

						<th class="px-6 py-4 text-sm font-medium text-zinc-400">
							Created At
						</th>
					</tr>
				</thead>

				<tbody>
					{{ range .Rules }}
					<tr class="border-b border-zinc-800">
						<td class="px-6 py-4">
							{{ .Type }}
						</td>

						<td class="px-6 py-4">
							{{ .Target }}
						</td>

						<td class="py-3 px-3">
							{{ if eq .Priority "high" }}
							<span class="px-2 py-1 rounded bg-green-500/10 text-green-400 text-xs">
								high
							</span>
							{{ else if eq .Priority "low" }}
							<span class="px-2 py-1 rounded bg-yellow-500/10 text-yellow-400 text-xs">
								low
							</span>
							{{ end }}
						</td>

						<td class="px-6 py-4">
							{{ .CreatedAt }}
						</td>
					</tr>
					{{ end }}
				</tbody>
			</table>
		</div>

	</section>

	<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
		<div class="flex items-center justify-between mb-4">
			<p class="text-sm text-zinc-400">
				Network Interfaces
			</p>

			<span class="text-xs text-zinc-500">
				TC status
			</span>
		</div>

		<div class="space-y-3 text-sm">
			{{ range .Ifaces }}
			{{ $dotColor := "bg-red-500" }}
			{{ if .Enabled }}
			{{ $dotColor = "bg-green-500" }}
			{{ end }}
			<div class="flex items-center justify-between py-2">
				<div class="flex items-center gap-3">
					<span class="{{ $dotColor }} h-3 w-3 rounded-full"></span>
					<span class="text-base font-medium">
						{{ .Name }}
					</span>
				</div>
				<span class="text-sm text-zinc-400">
					{{ if .Enabled }}Enabled{{ else }}Disabled{{ end }}
				</span>

			</div>
			{{ end }}

		</div>
	</div>
</main>
{{ end }}
