{{ define "content" }}
<main class="flex-1 p-8">
	<div class="mt-8 grid grid-cols-1 lg:grid-cols-2 gap-8">

		<!-- FORM -->
		<section class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<form hx-post="/rules/create" hx-target="#rules-table" hx-swap="beforeend" class="space-y-5">

				<!-- Rule Type -->
				<div>
					<label class="block text-sm text-zinc-300 mb-2">
						Rule Type
					</label>

					<select name="type" class="w-full rounded-lg bg-zinc-800 border border-zinc-700 px-3 py-2">
						<option value="ip">IP Address</option>
						<option value="domain">Domain</option>
					</select>
				</div>

				<!-- Target -->
				<div>
					<label class="block text-sm text-zinc-300 mb-2">
						IP Address / Domain
					</label>

					<input name="target" placeholder="e.g. 192.168.1.10 or youtube.com"
						class="w-full rounded-lg bg-zinc-800 border border-zinc-700 px-3 py-2" />
				</div>


				<!-- Priority -->
				<div>
					<label class="block text-sm text-zinc-300 mb-2">
						Priority Level
					</label>

					<select name="priority" class="w-full rounded-lg bg-zinc-800 border border-zinc-700 px-3 py-2">
						<option value="low">Low</option>
						<option value="high">High</option>
					</select>
				</div>


				<!-- Submit -->
				<button type="submit"
					class="w-full rounded-lg bg-blue-600 py-3 font-semibold hover:bg-blue-500 transition">
					Add Rule
				</button>

				<!-- Result -->
				<div id="rule-result" class="text-sm text-center text-zinc-400"></div>

			</form>

		</section>

		<!-- INFO PANEL -->
		<section class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">

			<h3 class="text-lg font-semibold">Rule Preview</h3>

			<p class="text-sm text-zinc-400 mt-2">
				Your rule will be applied in real time to the QoS engine.
			</p>

			<div class="mt-6 space-y-3 text-sm">

				<div class="p-3 rounded-lg bg-zinc-800">
					<p class="text-zinc-400">Example Rule</p>
					<p class="font-medium">youtube.com → LOW priority</p>
				</div>

				<div class="p-3 rounded-lg bg-zinc-800">
					<p class="text-zinc-400">Example Rule</p>
					<p class="font-medium">192.168.1.10 → HIGH priority</p>
				</div>

			</div>

			<div class="mt-6 text-xs text-zinc-500">
				Tip: Critical rules override all others.
			</div>

		</section>

	</div>

	<!-- CURRENT RULES -->
	<section class="mt-10 rounded-2xl border border-zinc-800 bg-zinc-900 p-6">

		<div class="flex items-center justify-between mb-4">
			<h3 class="text-lg font-semibold">Current Rules</h3>
		</div>

		<div class="overflow-x-auto">
			<table class="w-full text-sm text-left">

				<thead class="text-zinc-400 border-b border-zinc-800">
					<tr>
						<th class="py-2 px-3">Type</th>
						<th class="py-2 px-3">Target</th>
						<th class="py-2 px-3">Priority</th>
						<th class="py-2 px-3 text-right">Actions</th>
					</tr>
				</thead>

				<tbody id="rules-table" class="divide-y divide-zinc-800">

					{{ range .Rules }}
					<tr class="hover:bg-zinc-800/50 transition">
						<td class="py-3 px-3 text-zinc-300">{{ .Type }}</td>
						<td class="py-3 px-3">{{ .Target }}</td>
						<td class="py-3 px-3">
							{{ if eq .Priority "high" }}
							<span class="px-2 py-1 rounded bg-green-500/10 text-green-400 text-xs">
								high
							</span>
							{{ else if eq .Priority "low" }}
							<span class="px-2 py-1 rounded bg-yellow-500/10 text-yellow-400 text-xs">
								low
							</span>
							{{ end }}
						</td>
						<td class="py-3 px-3 text-right">
							<button hx-delete="/rules/{{ .Type }}/{{ .ID }}" hx-target="closest tr" hx-swap="outerHTML"
								class="text-red-400 hover:text-red-300 text-xs">
								Remove
							</button>
						</td>
					</tr>
					{{ end }}
				</tbody>

			</table>
		</div>

		<!-- Empty state (optional server toggle) -->
		<div class="mt-4 text-center text-zinc-500 text-sm hidden" id="empty-rules">
			No rules defined yet.
		</div>

	</section>

</main>
{{ end }}
