{{ define "content" }}
<main class="flex-1 p-8 space-y-6">
	<!-- Filters -->
	<section class="flex flex-col md:flex-row gap-4 md:items-center md:justify-between">

		<div class="flex gap-3">
			<select name="event_filter" hx-get="/logs/filter" hx-trigger="change" hx-target="#logs"
				class="bg-zinc-900 border border-zinc-800 rounded-lg px-3 py-2 text-sm">
				<option value="all">All Types</option>
				<option value="info">Info</option>
				<option value="warning">Warning</option>
				<option value="error">Error</option>
				<option value="dns">DNS</option>
				<option value="rule">Rule</option>
				<option value="tc">Traffic Control</option>
			</select>

		</div>
		<div>
			<button hx-delete="/logs/delete" hx-confirm="Are you sure you want to clear all logs?" hx-target="#logs"
				class="bg-red-600 hover:bg-red-700 text-white rounded-lg px-4 py-2 text-sm font-medium transition-colors">
				Clear Logs
			</button>
		</div>

	</section>

	<!-- Log stream -->
	<section class="rounded-2xl border border-zinc-800 bg-zinc-900 overflow-hidden">

		<!-- header -->
		<div class="px-6 py-4 border-b border-zinc-800 flex justify-between items-center">

			<div>
				<h3 class="text-lg font-semibold">Live Log Stream</h3>
				<p class="text-sm text-zinc-400">Latest system events</p>
			</div>


		</div>

		<div class="p-6 space-y-3 font-mono text-sm" id="logs">
			{{ block "logs_view.tmpl" . }} {{ end }}
		</div>

	</section>

	<!-- Footer stats -->
	<section class="grid grid-cols-1 md:grid-cols-3 gap-6">

		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">Total Logs</p>
			<h3 class="text-2xl font-bold mt-2">{{- .Logs | len }}</h3>
		</div>

		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">Total Warnings</p>
			<h3 class="text-2xl font-bold mt-2 text-yellow-400">{{- .Stats.Warnings }}</h3>
		</div>

		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">Total Errors</p>
			<h3 class="text-2xl font-bold mt-2 text-red-400">{{- .Stats.Errors }}</h3>
		</div>

	</section>

</main>
{{ end }}
