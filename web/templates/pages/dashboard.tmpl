{{ define "content" }}
<main class="flex-1 p-8 space-y-8 overflow-y-auto">
	<!-- Stats Cards -->
	<section class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">

		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">
				Active Rules
			</p>

			<h3 class="mt-2 text-3xl font-bold">
				24
			</h3>
		</div>

		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">
				Managed Domains
			</p>

			<h3 class="mt-2 text-3xl font-bold">
				13
			</h3>
		</div>

		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">
				High Priority Devices
			</p>

			<h3 class="mt-2 text-3xl font-bold">
				8
			</h3>
		</div>

		<div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
			<p class="text-sm text-zinc-400">
				QoS Engine
			</p>

			{{ if .Settings.QoSEnabled }}
			<div class="mt-3 flex items-center gap-2">
				<div class="h-3 w-3 rounded-full bg-green-500"></div>

				<span class="font-medium text-green-400">
					Online
				</span>
			</div>
			{{ else }}
			<div class="mt-3 flex items-center gap-2">
				<div class="h-3 w-3 rounded-full bg-red-500"></div>

				<span class="font-medium text-red-400">
					Offline
				</span>
			</div>
			{{ end }}
		</div>

	</section>

	<!-- Traffic Rules Table -->
	<section class="rounded-2xl border border-zinc-800 bg-zinc-900">

		<div class="flex items-center justify-between border-b border-zinc-800 px-6 py-4">

			<div>
				<h3 class="text-lg font-semibold">
					Recent Traffic Rules
				</h3>

				<p class="text-sm text-zinc-400">
					Currently active QoS policies
				</p>
			</div>

			<button class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium transition hover:bg-blue-500">
				<a href="/rules">Add Rule</a>
			</button>

		</div>

		<div class="overflow-x-auto">

			<table class="w-full text-left">

				<thead class="border-b border-zinc-800 bg-zinc-950/50">

					<tr>

						<th class="px-6 py-4 text-sm font-medium text-zinc-400">
							IP Address
						</th>

						<th class="px-6 py-4 text-sm font-medium text-zinc-400">
							Domain
						</th>

						<th class="px-6 py-4 text-sm font-medium text-zinc-400">
							Priority
						</th>

						<th class="px-6 py-4 text-sm font-medium text-zinc-400">
							Status
						</th>

						<th class="px-6 py-4 text-sm font-medium text-zinc-400">
							Actions
						</th>

					</tr>

				</thead>

				<tbody>

					<tr class="border-b border-zinc-800">

						<td class="px-6 py-4">
							192.168.1.20
						</td>

						<td class="px-6 py-4">
							youtube.com
						</td>

						<td class="px-6 py-4">
							<span class="rounded-full bg-yellow-500/20 px-3 py-1 text-sm text-yellow-400">
								Medium
							</span>
						</td>

						<td class="px-6 py-4">
							<span class="text-green-400">
								Active
							</span>
						</td>

						<td class="px-6 py-4">
							<button class="text-sm text-blue-400 hover:text-blue-300">
								Edit
							</button>
						</td>

					</tr>

					<tr class="border-b border-zinc-800">

						<td class="px-6 py-4">
							192.168.1.45
						</td>

						<td class="px-6 py-4">
							netflix.com
						</td>

						<td class="px-6 py-4">
							<span class="rounded-full bg-red-500/20 px-3 py-1 text-sm text-red-400">
								Low
							</span>
						</td>

						<td class="px-6 py-4">
							<span class="text-green-400">
								Active
							</span>
						</td>

						<td class="px-6 py-4">
							<button class="text-sm text-blue-400 hover:text-blue-300">
								Edit
							</button>
						</td>

					</tr>

					<tr>

						<td class="px-6 py-4">
							192.168.1.12
						</td>

						<td class="px-6 py-4">
							zoom.us
						</td>

						<td class="px-6 py-4">
							<span class="rounded-full bg-green-500/20 px-3 py-1 text-sm text-green-400">
								High
							</span>
						</td>

						<td class="px-6 py-4">
							<span class="text-green-400">
								Active
							</span>
						</td>

						<td class="px-6 py-4">
							<button class="text-sm text-blue-400 hover:text-blue-300">
								Edit
							</button>
						</td>

					</tr>

				</tbody>

			</table>

		</div>

	</section>

	<!-- Recent Activity -->
	<section class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">

		<h3 class="text-lg font-semibold">
			Recent Activity
		</h3>

		<div class="mt-4 space-y-4 text-sm">

			<div class="flex items-start gap-3">
				<div class="mt-1 h-2 w-2 rounded-full bg-green-500"></div>

				<p class="text-zinc-300">
					Applied HIGH priority to
					<span class="font-medium text-white">
						192.168.1.12
					</span>
				</p>
			</div>

			<div class="flex items-start gap-3">
				<div class="mt-1 h-2 w-2 rounded-full bg-blue-500"></div>

				<p class="text-zinc-300">
					Reloaded QoS policies successfully
				</p>
			</div>

			<div class="flex items-start gap-3">
				<div class="mt-1 h-2 w-2 rounded-full bg-yellow-500"></div>

				<p class="text-zinc-300">
					New domain rule added for
					<span class="font-medium text-white">
						youtube.com
					</span>
				</p>
			</div>

		</div>

	</section>

</main>
{{ end }}
